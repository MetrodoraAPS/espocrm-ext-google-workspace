{
    "implementationClassName": "Espo\\Modules\\GoogleWorkspace\\Authentication\\GoogleWorkspace\\Login",
    "logoutClassName": "Espo\\Modules\\GoogleWorkspace\\Authentication\\GoogleWorkspace\\Logout",
    "login": {
        "handler": "google-workspace:handlers/login/google-workspace",
        "fallbackConfigParam": "googleWorkspaceAllowAdminFallback"
    },
    "provider": {
        "isAvailable": true
    },
    "settings": {
        "isAvailable": true,
        "layout": {
            "label": "Google Workspace",
            "rows": [
                [
                    {"name": "googleWorkspaceClientId"}
                ],
                [
                    {"name": "googleWorkspaceClientSecret"}
                ],
                [
                    {
                        "name": "googleWorkspaceRedirectUri",
                        "view": "views/settings/fields/oidc-redirect-uri",
                        "params": {
                            "readOnly": true,
                            "copyToClipboard": true
                        }
                    }
                ],
                [
                    {"name": "googleWorkspaceHostedDomain"}
                ],
                [
                    {"name": "googleWorkspaceCreateUser"}
                ],
                [
                    {"name": "googleWorkspaceAllowAdminFallback"}
                ],
                [
                    {"name": "googleWorkspaceAllowRegularFallback"}
                ],
                [
                    {"name": "googleWorkspaceServiceAccount"}
                ],
                [
                    {"name": "googleWorkspaceAdminEmail"}
                ],
                [
                    {"name": "googleWorkspaceSyncOnLogin"}
                ],
                [
                    {"name": "googleWorkspaceEnableSync"}
                ],
                [
                    {
                        "name": "googleWorkspaceSyncFrequency",
                        "dependency": {
                            "type": "equals",
                            "attribute": "googleWorkspaceEnableSync",
                            "value": true
                        }
                    }
                ],
                [
                    {"name": "googleWorkspaceUserWhitelistGroups"}
                ],
                [
                    {"name": "googleWorkspaceSyncEmails"}
                ],
                [
                    {"name": "googleWorkspaceSyncNames"}
                ],
                [
                    {"name": "googleWorkspaceSyncPhones"}
                ],
                [
                    {"name": "googleWorkspaceSyncActive"}
                ],
                [
                    {"name": "googleWorkspaceAdminGroup"}
                ],
                [
                    {"name": "googleWorkspaceSyncAvatar"}
                ],
                [
                    {"name": "googleWorkspaceSyncGroups"}
                ]
            ]
        },
        "fieldList": [
            "googleWorkspaceClientId",
            "googleWorkspaceClientSecret",
            "googleWorkspaceRedirectUri",
            "googleWorkspaceHostedDomain",
            "googleWorkspaceCreateUser",
            "googleWorkspaceAllowAdminFallback",
            "googleWorkspaceAllowRegularFallback",
            "googleWorkspaceServiceAccount",
            "googleWorkspaceAdminEmail",
            "googleWorkspaceSyncOnLogin",
            "googleWorkspaceEnableSync",
            "googleWorkspaceSyncFrequency",
            "googleWorkspaceUserWhitelistGroups",
            "googleWorkspaceSyncEmails",
            "googleWorkspaceSyncNames",
            "googleWorkspaceSyncPhones",
            "googleWorkspaceSyncActive",
            "googleWorkspaceAdminGroup",
            "googleWorkspaceSyncAvatar",
            "googleWorkspaceSyncGroups"
        ],
        "dynamicLogic": {
            "fields": {
                "googleWorkspaceClientId": {
                    "required": {
                        "conditionGroup": [
                            {
                                "type": "equals",
                                "attribute": "authenticationMethod",
                                "value": "GoogleWorkspace"
                            }
                        ]
                    }
                },
                "googleWorkspaceClientSecret": {
                    "required": {
                        "conditionGroup": [
                            {
                                "type": "equals",
                                "attribute": "authenticationMethod",
                                "value": "GoogleWorkspace"
                            }
                        ]
                    }
                }
            }
        }
    }
}
